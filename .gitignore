# ====================
# 包含规则（不要忽略这些文件）
# ====================
# 保留版本控制文件
!/.gitignore
!/README.md
!/LICENSE

# 保留配置文件
!/_config.yml
!/Gemfile

# 保留数据文件
!/_data/

# 保留源文件
!/_layouts/
!/_includes/
!/_locales/
!/assets/

# 保留主页
!/index.html
!/404.html

# 保留文档
!/docs/
!/_posts/